generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  clerkId      String   @unique
  email        String   @unique
  name         String?
  role                String    @default("user")
  googleTokens        Json?
  defaultVisualStyle  Json?     // stile di default per eventi senza folder
  seendoTokensUsed    Int       @default(0)   // token Gemini consumati nella finestra rolling corrente
  seendoTokensResetAt DateTime?              // inizio della finestra rolling 24h
  seendoTokensMonthly Int       @default(0)  // accumulo mensile (mese solare)
  seendoMonthYear     String?               // es. "2025-01" — mese a cui si riferisce il contatore mensile
  seendoCallsToday    Int       @default(0)  // chiamate nella finestra rolling corrente (condivide seendoTokensResetAt)
  seendoStorageBytes  BigInt    @default(0)  // byte totali occupati su R2 (immagini OCR + allegati eventi)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  folders       Folder[]
  events        Event[]
  chips         Chip[]
  palettes      Palette[]
  folderFields  FolderField[]
  seendoUploads SeendoUpload[]
  seendoTokenLogs SeendoTokenLog[]
  weeklyNotes   WeeklyNote[]
  dailyNotes    DailyNote[]
}

model Folder {
  id          String   @id @default(cuid())
  name        String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  visualStyle Json?
  color       String?
  icon        String?
  createdAt   DateTime @default(now())

  events       Event[]
  chips        Chip[]
  folderFields FolderField[]
}

// Campi custom definiti per una cartella
model FolderField {
  id        String   @id @default(cuid())
  folderId  String
  folder    Folder   @relation(fields: [folderId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  fieldType String   // "text" | "number" | "closed_list" | "boolean"
  options   Json?    // per closed_list: array di stringhe
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime

  // Timing avanzato
  isFullDay         Boolean @default(false)
  isFlexible        Boolean @default(false)
  timezone          String?
  qualitativeTiming String?  // "morning"|"midday"|"afternoon"|"evening"|"night"

  // Location
  location    String?
  locationUrl String?

  // Ripetizione
  repetition    Json?    // { type, days?, endDate?, count? } — solo sul parent
  parentEventId String?  // se impostato, questo è un'occorrenza di una serie

  // Self-relation: occorrenze della serie
  parent      Event?  @relation("EventOccurrences", fields: [parentEventId], references: [id], onDelete: SetNull)
  occurrences Event[] @relation("EventOccurrences")

  // Relazioni
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id])

  // Stile visivo
  visualStyle Json?

  // Sync esterno (Lindo)
  externalId       String?
  source           String?  // "google" | "notion" | "plandoom"
  isExternalLinked Boolean @default(false)

  // Seendo
  seendoImages         Json?
  seendoSourceUploadId String?
  seendoUpload         SeendoUpload? @relation("SeendoSource", fields: [seendoSourceUploadId], references: [id], onDelete: SetNull)
  seendoFiles          Json?    // array di { url, key, name, size, type }

  // Prodo
  mentalEnergy      Int?
  physicalEnergy    Int?
  difficulty        Int?
  pleasure          Int?
  isFixed           Boolean @default(false)
  allowMultiDay     Boolean @default(false)
  productivityModel String?

  // Campi custom cartella
  folderFieldValues Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Chip {
  id          String    @id @default(cuid())
  title       String
  description String?

  // Posizione
  area       String    @default("weekly")  // "daily" | "weekly" | "pouch"
  dayTarget  DateTime?
  weekNumber Int?
  year       Int?

  // Dati chip
  duration    Int?
  location    String?
  locationUrl String?

  // Relazioni
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id])

  // Stile visivo
  visualStyle Json?

  // Prodo
  mentalEnergy     Int?
  physicalEnergy   Int?
  difficulty       Int?
  optimalityTarget Int?

  // Campi custom cartella
  folderFieldValues Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Palette {
  id        String   @id @default(cuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  colors    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShapePreset {
  id          String   @id @default(cuid())
  name        String
  visualStyle Json     // { path, smoothing, fillColor, frameColor }
  createdAt   DateTime @default(now())
}

model SeendoUpload {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  imageUrl         String   // URL immagine su R2 reading bucket
  documentType     String?
  referencePeriod  String?
  timezone         String?
  extractedEvents  Json     // SeendoExtractedEvent[]
  importedEventIds String[] // ID degli eventi effettivamente importati
  fileSizeBytes    Int?     // dimensione in byte dell'immagine OCR su R2
  createdAt        DateTime @default(now())

  importedEvents   Event[]  @relation("SeendoSource")
}

model SeendoTokenLog {
  id        String   @id @default(cuid())
  userId    String
  tokens    Int
  model     String   // "gemini-2.5-flash" | "gemini-2.0-flash"
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeeklyNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  weekStart DateTime // sempre mezzanotte del lunedì della settimana (UTC)
  content   Json     // Tiptap HTML output
  updatedAt DateTime @updatedAt

  @@unique([userId, weekStart])
}

model DailyNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime // mezzanotte UTC del giorno
  content   Json     // Tiptap HTML output
  iconColor String   @default("#c9a84c") // doom-gold come default
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}
